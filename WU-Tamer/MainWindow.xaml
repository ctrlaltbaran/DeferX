<Window x:Class="Wu_change.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wu_change"
        mc:Ignorable="d"
        Title="WU-Tamer — Windows Update Manager"
        Height="720" Width="1080"
        MinHeight="500" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}">

    <Window.Resources>
        <local:SeverityColorConverter x:Key="SeverityColorConverter"/>
        <local:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- Button style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BtnPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button style -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#5A2D82"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5A2D82"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7B40B0"/>
                    <Setter Property="BorderBrush" Value="#7B40B0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#4A2070"/>
                    <Setter Property="BorderBrush" Value="#4A2070"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7B40B0"/>
                                <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle switch style -->
        <Style x:Key="ModernToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="track" Width="40" Height="20" CornerRadius="10"
                                    Background="{DynamicResource BorderColor}">
                                <Border x:Name="thumb" Width="14" Height="14" CornerRadius="7"
                                        Background="White" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#7B40B0"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView style -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource BgSecondary}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="Padding" Value="4,3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ListHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Expander style for collapsible history groups -->
        <Style x:Key="GroupExpander" TargetType="Expander">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,4,0,0"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource BgPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="0" Padding="12,10"
                Background="{DynamicResource BgSecondary}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ScanCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="15" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Scan for Updates" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding InstallSelectedCommand}"
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↓" FontSize="15" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Install Selected" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="22" Margin="4,0,12,0"
                               Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>

                    <Button Command="{Binding HideSelectedCommand}"
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,8,0"
                            ToolTip="Hide — prevents automatic install">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊘" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Hide" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding UnhideSelectedCommand}"
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,8,0"
                            ToolTip="Unhide — makes update available again">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👁" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Unhide" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="22" Margin="4,0,12,0"
                               Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>

                    <Button Command="{Binding CancelCommand}"
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Software + Drivers kept as one unit so they always wrap together -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Rectangle Width="1" Height="22" Margin="0,0,12,0"
                                   Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding IncludeSoftware}"
                                  Style="{StaticResource ModernToggle}"
                                  Content="Software"
                                  Foreground="{DynamicResource FgPrimary}"
                                  Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding IncludeDrivers}"
                                  Style="{StaticResource ModernToggle}"
                                  Content="Drivers"
                                  Foreground="{DynamicResource FgPrimary}"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </WrapPanel>

                <!-- Dark mode lightbulb button -->
                <Button Grid.Column="1"
                        Command="{Binding ToggleDarkModeCommand}"
                        Style="{StaticResource ModernButton}"
                        Padding="8,6"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        ToolTip="Toggle light/dark mode">
                    <TextBlock Text="💡" FontSize="18">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                        <Setter Property="Opacity" Value="0.35"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ TAB BAR ═══ -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgSecondary}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderColor}">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="TabUpdates" Content="Available Updates"
                             Style="{StaticResource TabButton}"
                             IsChecked="True"
                             GroupName="MainTabs"
                             Foreground="{DynamicResource FgPrimary}"/>
                <RadioButton x:Name="TabHistory" Content="Update History"
                             Style="{StaticResource TabButton}"
                             GroupName="MainTabs"
                             Foreground="{DynamicResource FgPrimary}"/>
            </StackPanel>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="2">

            <!-- Updates panel -->
            <Grid Visibility="{Binding IsChecked, ElementName=TabUpdates, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasNoUpdates, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="⟳" FontSize="56" HorizontalAlignment="Center"
                               Foreground="{DynamicResource FgSecondary}" Margin="0,0,0,12"/>
                    <TextBlock Text="Click Scan to check for updates"
                               FontSize="15" Foreground="{DynamicResource FgSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12,16,12"
                              Visibility="{Binding HasNoUpdates, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding UpdateGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,16">

                                    <!-- Group header -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding GroupName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#7B40B0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <Rectangle Grid.Column="1" Height="1" VerticalAlignment="Center"
                                                   Fill="{DynamicResource BorderColor}"/>
                                        <Border Grid.Column="2" CornerRadius="10"
                                                Background="{DynamicResource BgTertiary}"
                                                Padding="8,2" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Items.Count}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource FgSecondary}"/>
                                        </Border>
                                    </Grid>

                                    <ListView ItemsSource="{Binding Items}" SelectionMode="Extended">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Width="40">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      HorizontalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Title" Width="370">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Title}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Title}"
                                                                       Foreground="{DynamicResource FgPrimary}"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Category" Width="155"
                                                                DisplayMemberBinding="{Binding Category}"/>
                                                <GridViewColumn Header="KB Article" Width="90"
                                                                DisplayMemberBinding="{Binding KBString}"/>
                                                <GridViewColumn Header="Date" Width="88"
                                                                DisplayMemberBinding="{Binding LastDeploymentChangeTime, StringFormat='{}{0:M/d/yyyy}'}"/>
                                                <GridViewColumn Header="Size" Width="78"
                                                                DisplayMemberBinding="{Binding SizeString}"/>
                                                <GridViewColumn Header="State" Width="100">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="4" Padding="7,2"
                                                                    Background="{Binding StatusString, Converter={StaticResource StatusToColorConverter}}">
                                                                <TextBlock Text="{Binding StatusString}"
                                                                           FontSize="11" Foreground="White"
                                                                           HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ListHover}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SelectionBg}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- History panel with grouped and flat list views -->
            <Grid Visibility="{Binding IsChecked, ElementName=TabHistory, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="16,10"
                        Background="{DynamicResource BgSecondary}"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource BorderColor}">
                    <StackPanel Orientation="Vertical">
                        <!-- Buttons row -->
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Command="{Binding LoadHistoryCommand}"
                                    Style="{StaticResource ModernButton}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Load History" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Rectangle Width="1" Height="22" Margin="12,0,12,0"
                                       Fill="{DynamicResource BorderColor}" VerticalAlignment="Center"/>

                            <!-- View toggle -->
                            <TextBlock Text="View:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="{DynamicResource FgSecondary}"/>
                            <RadioButton Content="Grouped" GroupName="HistoryView" Margin="0,0,12,0" VerticalAlignment="Center" IsChecked="True"/>
                            <RadioButton Content="Flat List" GroupName="HistoryView" VerticalAlignment="Center"/>
                        </WrapPanel>

                        <!-- Filter row -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="{DynamicResource FgSecondary}"/>
                            <ItemsControl ItemsSource="{Binding HistoryGroupFilter}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Key}"
                                                  IsChecked="{Binding Value, Mode=TwoWay}"
                                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Grouped View -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,12"
                              Visibility="{Binding HistoryIsGrouped, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding HistoryGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Style="{StaticResource GroupExpander}"
                                          IsExpanded="True"
                                          Margin="0,0,0,12">
                                    <Expander.Header>
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding GroupName}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#7B40B0"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <Rectangle Grid.Column="1" Height="1" VerticalAlignment="Center"
                                                       Fill="{DynamicResource BorderColor}"/>
                                            <Border Grid.Column="2" CornerRadius="10"
                                                    Background="{DynamicResource BgTertiary}"
                                                    Padding="8,2" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Items.Count}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource FgSecondary}"/>
                                            </Border>
                                        </Grid>
                                    </Expander.Header>

                                    <!-- Items list with collapsible duplicate attempts -->
                                    <StackPanel Margin="0,4,0,0">
                                        <!-- Column headers -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="382"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Text="Title" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FgSecondary}"/>
                                            <TextBlock Grid.Column="2" Text="KB Article" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FgSecondary}"/>
                                            <TextBlock Grid.Column="3" Text="Date" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FgSecondary}"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <!-- Latest attempt row -->
                                                        <Grid Margin="0,1,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="18"/>
                                                                <ColumnDefinition Width="382"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="140"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Expand toggle, only shown when duplicates exist -->
                                                            <ToggleButton Grid.Column="0"
                                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                                          Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                          Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}"
                                                                          Background="Transparent" BorderThickness="0"
                                                                          Width="16" Height="16" Padding="0"
                                                                          VerticalAlignment="Center">
                                                                <ToggleButton.Content>
                                                                    <TextBlock FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="▶"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                        <Setter Property="Text" Value="▼"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </ToggleButton.Content>
                                                            </ToggleButton>
                                                            <TextBlock Grid.Column="1" Text="{Binding Latest.Title}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Latest.Title}"
                                                                       Foreground="{DynamicResource FgPrimary}"
                                                                       VerticalAlignment="Center" Padding="2,3"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Latest.KBString}"
                                                                       Foreground="{DynamicResource FgPrimary}"
                                                                       VerticalAlignment="Center" Padding="2,3"/>
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding Latest.LastDeploymentChangeTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                                       Foreground="{DynamicResource FgPrimary}"
                                                                       VerticalAlignment="Center" Padding="2,3"/>
                                                        </Grid>
                                                        <!-- Older attempts, shown when expanded -->
                                                        <ItemsControl ItemsSource="{Binding OlderAttempts}"
                                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,1,0,1">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="18"/>
                                                                            <ColumnDefinition Width="382"/>
                                                                            <ColumnDefinition Width="90"/>
                                                                            <ColumnDefinition Width="140"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   ToolTip="{Binding Title}"
                                                                                   Foreground="{DynamicResource FgSecondary}"
                                                                                   VerticalAlignment="Center" Padding="2,3"/>
                                                                        <TextBlock Grid.Column="2" Text="{Binding KBString}"
                                                                                   Foreground="{DynamicResource FgSecondary}"
                                                                                   VerticalAlignment="Center" Padding="2,3"/>
                                                                        <TextBlock Grid.Column="3"
                                                                                   Text="{Binding LastDeploymentChangeTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                                                   Foreground="{DynamicResource FgSecondary}"
                                                                                   VerticalAlignment="Center" Padding="2,3"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Flat List View -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,12"
                              Visibility="{Binding HistoryIsGrouped, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel>
                        <!-- Column headers -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="352"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Title" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FgSecondary}"/>
                            <TextBlock Grid.Column="2" Text="Group" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FgSecondary}"/>
                            <TextBlock Grid.Column="3" Text="KB Article" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FgSecondary}"/>
                            <TextBlock Grid.Column="4" Text="Date" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FgSecondary}"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding HistoryFlat}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <!-- Latest attempt row -->
                                        <Grid Margin="0,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="352"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0"
                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Visibility="{Binding HasMultiple, Converter={StaticResource BoolToVisibilityConverter}}"
                                                          Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}"
                                                          Background="Transparent" BorderThickness="0"
                                                          Width="16" Height="16" Padding="0"
                                                          VerticalAlignment="Center">
                                                <ToggleButton.Content>
                                                    <TextBlock FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="▶"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Text" Value="▼"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </ToggleButton.Content>
                                            </ToggleButton>
                                            <TextBlock Grid.Column="1" Text="{Binding Latest.Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Latest.Title}"
                                                       Foreground="{DynamicResource FgPrimary}"
                                                       VerticalAlignment="Center" Padding="2,3"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Latest.GroupName}"
                                                       Foreground="{DynamicResource FgPrimary}"
                                                       VerticalAlignment="Center" Padding="2,3"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Latest.KBString}"
                                                       Foreground="{DynamicResource FgPrimary}"
                                                       VerticalAlignment="Center" Padding="2,3"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Latest.LastDeploymentChangeTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       Foreground="{DynamicResource FgPrimary}"
                                                       VerticalAlignment="Center" Padding="2,3"/>
                                        </Grid>
                                        <!-- Older attempts -->
                                        <ItemsControl ItemsSource="{Binding OlderAttempts}"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1,0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18"/>
                                                            <ColumnDefinition Width="352"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="140"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Title}"
                                                                   Foreground="{DynamicResource FgSecondary}"
                                                                   VerticalAlignment="Center" Padding="2,3"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding GroupName}"
                                                                   Foreground="{DynamicResource FgSecondary}"
                                                                   VerticalAlignment="Center" Padding="2,3"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding KBString}"
                                                                   Foreground="{DynamicResource FgSecondary}"
                                                                   VerticalAlignment="Center" Padding="2,3"/>
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding LastDeploymentChangeTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                                   Foreground="{DynamicResource FgSecondary}"
                                                                   VerticalAlignment="Center" Padding="2,3"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Padding="16,7"
                Background="{DynamicResource BgSecondary}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource FgSecondary}"/>
                <ProgressBar Grid.Column="1" Height="3" IsIndeterminate="True"
                             Foreground="#7B40B0"
                             Background="Transparent"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
