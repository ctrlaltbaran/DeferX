<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgPrimary"    Color="#F3F3F3"/>
    <SolidColorBrush x:Key="BgSecondary"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgTertiary"   Color="#E8E8E8"/>
    <SolidColorBrush x:Key="FgPrimary"    Color="#1A1A1A"/>
    <SolidColorBrush x:Key="FgSecondary"  Color="#666666"/>
    <SolidColorBrush x:Key="BorderColor"  Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BtnBg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BtnHover"     Color="#F0F0F0"/>
    <SolidColorBrush x:Key="BtnPressed"   Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SelectionBg"  Color="#DDD0F5"/>
    <SolidColorBrush x:Key="ListHover"    Color="#EDE0FF"/>

    <!-- Prevent system blue hover on list controls and dialogs -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                       Color="Transparent"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                   Color="#1A1A1A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"      Color="#E8E8E8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"  Color="#1A1A1A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"                         Color="#FFFFFF"/>
</ResourceDictionary>
