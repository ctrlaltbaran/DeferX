<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgPrimary"    Color="#202020"/>
    <SolidColorBrush x:Key="BgSecondary"  Color="#2C2C2C"/>
    <SolidColorBrush x:Key="BgTertiary"   Color="#383838"/>
    <SolidColorBrush x:Key="FgPrimary"    Color="#F0F0F0"/>
    <SolidColorBrush x:Key="FgSecondary"  Color="#AAAAAA"/>
    <SolidColorBrush x:Key="BorderColor"  Color="#444444"/>
    <SolidColorBrush x:Key="BtnBg"        Color="#3A3A3A"/>
    <SolidColorBrush x:Key="BtnHover"     Color="#484848"/>
    <SolidColorBrush x:Key="BtnPressed"   Color="#555555"/>
    <SolidColorBrush x:Key="SelectionBg"  Color="#4A2070"/>
    <SolidColorBrush x:Key="ListHover"    Color="#3D1A5C"/>

    <!-- Override WPF system highlight colors so list items don't get the glossy OS theme on hover/selection -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                       Color="Transparent"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                   Color="#F0F0F0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"      Color="#383838"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"  Color="#AAAAAA"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"                         Color="#2C2C2C"/>
</ResourceDictionary>
